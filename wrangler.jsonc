{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dhc6-trainer-website",
  "main": "worker.js",
  "compatibility_date": "2026-06-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true,
    "exclude": [
      ".git/**",
      ".github/**",
      ".idea/**",
      ".wrangler/**",
      "tools/**",
      "functions/**",
      "downloads/desktop/*.exe",
      "downloads/desktop/*.msi",
      "downloads/desktop/*.dmg",
      "downloads/desktop/*.deb"
    ]
  },
  // Add the LICENSES KV namespace and Paddle secrets in the Cloudflare
  // dashboard under this Worker's Bindings and Variables settings.
}
